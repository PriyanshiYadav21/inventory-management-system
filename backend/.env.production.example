# Production Environment Configuration
# Use this template for production deployments
# IMPORTANT: Never commit actual values - use environment variables

# Database Configuration
# For Neon PostgreSQL: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://prod_user:CHANGE_ME_STRONG_PASSWORD@db-host:5432/inventory_db

# Application Settings
ENVIRONMENT=production
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_KEY_MIN_32_CHARS
DEBUG=False

# Security
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Frontend URL for CORS
FRONTEND_URL=https://your-frontend-domain.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/inventory/app.log

# Optional: Redis Cache (for future enhancement)
# REDIS_URL=redis://redis-host:6379/0

# Optional: Email Configuration
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# ADMIN_EMAIL=admin@your-domain.com

# Optional: Sentry Error Tracking
# SENTRY_DSN=https://key@sentry.io/project-id

# File Storage (AWS S3 - Optional)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=inventory-bucket
# AWS_REGION=us-east-1
